# Copy to .env for local testing:  cp .env.example .env  then fill in.
# In production these live as GitHub repo secrets, NOT in this file.

# SMTP server you'll send the digest *from*.
# Gmail: host=smtp.gmail.com port=587, and SMTP_PASS must be an App Password
# (Google Account → Security → 2-Step Verification → App passwords), not your
# normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=you@gmail.com

# Your Send-to-Kindle address (Amazon → Manage Your Content and Devices →
# Preferences → Personal Document Settings). The MAIL_FROM address above MUST
# be added there as an Approved Personal Document E-mail, or Amazon drops it.
KINDLE_EMAIL=yourname@kindle.com
